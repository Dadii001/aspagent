# Prospector tuning
PROSPECTOR_HOURS_AGO=72
PROSPECTOR_MAX_PAGES=20
TIKTOK_REQUEST_DELAY_MS=200

# Runtime
NODE_ENV=development
DB_PATH=./data/leads.json
